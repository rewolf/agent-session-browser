# Overrides global ~/.npmrc for keys defined here (per npm discovery from this tree).
registry=https://registry.npmjs.org/

# If TLS to registry.npmjs.org fails (UNABLE_TO_GET_ISSUER_CERT_LOCALLY) on a
# corporate network, prefer adding your CA bundle:
#   cafile=/path/to/your-ca-bundle.pem
# As a last resort only, override locally (do not commit):
#   npm config set strict-ssl false
strict-ssl=true

# Reject package versions published within the last N days (npm CLI 11.10.0+).
# Override for one install: npm install --min-release-age=0
min-release-age=5
